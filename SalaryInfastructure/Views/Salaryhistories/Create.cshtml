@model LibraryInfrastructure.Models.Salaryhistory

@{
    ViewData["Title"] = "Створення";
}

<h1>Створення</h1>

<h4>Історія виплат</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Scientistid" />

            <div class="form-group">
                <label class="control-label">Науковець</label>
                <input class="form-control" value="@ViewBag.ScientistName" readonly />
            </div>
            <div class="form-group">
                <label asp-for="Oldsalary" class="control-label"></label>
                <input asp-for="Oldsalary" class="form-control" />
                <span asp-validation-for="Oldsalary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Newsalary" class="control-label"></label>
                <input asp-for="Newsalary" class="form-control" />
                <span asp-validation-for="Newsalary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Reason" class="control-label"></label>
                <input asp-for="Reason" class="form-control" />
                <span asp-validation-for="Reason" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
