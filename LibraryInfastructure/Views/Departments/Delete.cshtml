@model LibraryInfrastructure.Models.Department

@{
    ViewData["Title"] = "Видалення";
}

<h1>Видалення</h1>

<h3>Ви впевнені, що хочете це видалити?</h3>
<div>
    <h4>Кафедра</h4>
