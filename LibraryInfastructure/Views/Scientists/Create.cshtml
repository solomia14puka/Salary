@model LibraryInfrastructure.Models.Scientist

@{
    ViewData["Title"] = "Cтворення";
}

<h1>Створення</h1>

<h4>Науковець</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Fullname" class="form-label"></label>
                <input asp-for="Fullname" class="form-control" />
                <span asp-validation-for="Fullname" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Кафедра</label>

                @if (ViewBag.DepartmentName != null)
                {
                    <input type="hidden" asp-for="Departmentid" />
                    <input class="form-control" value="@ViewBag.DepartmentName" readonly />
                }
                else
                {
                    <select asp-for="Departmentid" class="form-control" asp-items="ViewBag.Departmentid">
                        <option value="">-- Оберіть кафедру --</option>
                    </select>
                    <span asp-validation-for="Departmentid" class="text-danger"></span>
                }
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Посади</label>
                <select name="selectedPositionIds" class="form-control" asp-items="ViewBag.PositionId" multiple style="height: 120px;">
                </select>
                <span class="text-muted small">* Утримуйте Ctrl, щоб обрати кілька посад одночасно.</span>
            </div>
            <div class="form-group">
                <label asp-for="Salary" class="control-label">Базова ставка (грн)</label>
                <input asp-for="Salary" class="form-control" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Назад</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
