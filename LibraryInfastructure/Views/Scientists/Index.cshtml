@model IEnumerable<LibraryInfrastructure.Models.Scientist>

@{
    ViewData["Title"] = "Науковці";
}

<h1>Науковці @ViewBag.DepartmentName</h1>

<div class="d-flex gap-2 mb-3">
    <a asp-action="Create" class="btn btn-success">ДОДАТИ НАУКОВЦЯ</a>
    <a asp-controller="Positions" asp-action="Index" class="btn btn-success">КЕРУВАННЯ ПОСАДАМИ</a>
</div>
<form asp-action="Index" method="get" class="mb-3 d-flex justify-content-end">

    <input type="hidden" name="id" value="@ViewBag.DepartmentId" />
    <input type="hidden" name="name" value="@ViewBag.DepartmentName" />

    <div class="input-group" style="max-width: 400px;">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Пошук" />
        
        <button type="submit" class="btn btn-primary">Знайти</button>
        
        @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
        {
            <a asp-action="Index" asp-route-id="@ViewBag.DepartmentId" asp-route-name="@ViewBag.DepartmentName" class="btn btn-outline-secondary">
                Скинути
            </a>
        }
    </div>
</form>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Fullname)
            </th>
            <th>
                @Html.DisplayName("Посада")
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Salary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Createdat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Updatedat)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Department)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
            var currentAssignment = item.Scientistpositions
                .OrderByDescending(p => p.Startdate)
                .FirstOrDefault();
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Fullname)
            </td>
                <td>
                    @if (item.Scientistpositions != null && item.Scientistpositions.Any())
                    {
                        @string.Join(", ", item.Scientistpositions.Select(sp => sp.Position.Name))
                    }
                    else
                    {
                        <span class="text-muted">Не призначено</span>
                    }
                </td>
            <td>
                @Html.DisplayFor(modelItem => item.Salary)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Createdat)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Updatedat)
            </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Department.Name)
                </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Редагувати</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Деталі</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Видалити</a>
            </td>
        </tr>
}
    </tbody>
</table>
