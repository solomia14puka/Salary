@model LibraryInfrastructure.Models.Position

@{
    ViewData["Title"] = "Створення";
}


<h4>Посада</h4>
<hr />
<div class="row">
    <div class="container mt-5">
        <div class="card shadow-sm p-4 mx-auto border-0" style="max-width: 500px; border-radius: 12px;">
            <h3 class="text-center mb-4 text-secondary" style="font-weight: 600; letter-spacing: 1px;">
                НОВА ПОСАДА
            </h3>

            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
                <div class="form-group mb-4">
                    <label class="form-label text-muted fw-bold small text-uppercase">Назва посади</label>
                    <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="напр. Професор, Доцент" style="border-radius: 8px;" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="text-center mt-4 pt-2">
                    <button type="submit" class="btn btn-success w-100 py-3 shadow-sm mb-3" style="font-weight: 600; letter-spacing: 0.5px; border-radius: 8px;">
                        <i class="fas fa-check-circle me-1"></i> ЗБЕРЕГТИ ПОСАДУ
                    </button>
                    <a asp-action="Index" class="text-decoration-none text-muted small d-inline-block mt-2">
                        <i class="fas fa-arrow-left me-1"></i> Повернутися до списку
                    </a>
                </div>
            </form>
        </div>
    </div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
