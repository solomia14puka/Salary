@{
    ViewData["Title"] = "Головна сторінка";
}

<div class="text-center mb-5">
    <h1 class="display-4">Система обліку науковців та зарплат</h1>
    <p class="lead">Інформаційна система для управління персоналом та нарахуваннями.</p>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Структура</h5>
                <p class="card-text">Перегляд та редагування факультетів і кафедр.</p>
                <a asp-controller="Faculties" asp-action="Index" class="btn btn-primary">Відкрити факультети</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Персонал</h5>
                <p class="card-text">База даних усіх наукових співробітників системи.</p>
                <a asp-controller="Scientists" asp-action="Index" class="btn btn-outline-primary">Переглянути всіх</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
                <h5 class="card-title">Виплати</h5>
                <p class="card-text">Контроль історії нарахувань заробітної плати</p>
                <a asp-controller="Salaryhistories" asp-action="Index" class="btn btn-outline-secondary">Історія виплат</a>
            </div>
        </div>
    </div>
</div>