@model IEnumerable<LibraryInfrastructure.Controllers.FacultyBudgetInfo>
@{
    ViewData["Title"] = "Бюджет факультетів";
}

<div class="container mt-5">
    <h2 class="text-center mb-4">Фінансовий звіт: Аналітика по факультетах</h2>
    
    <div class="d-flex justify-content-end mb-3">
        <a asp-action="ExportFacultyBudgetToExcel" class="btn btn-success">
            Експорт в Excel
        </a>
    </div>
    <div class="card shadow border-0 rounded-lg">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center">#</th>
                        <th>Назва факультету</th>
                        <th class="text-end">Загальний бюджет (грн)</th>
                        <th class="text-end">Середня зарплата (грн)</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int counter = 1;
                        decimal totalUniversityBudget = 0;
                    }
                    @foreach (var item in Model)
                    {
                        totalUniversityBudget += item.TotalBudget;
                        <tr>
                            <td class="text-center text-muted">@counter</td>
                            <td class="fw-bold">@item.FacultyName</td>
                            <td class="text-end text-success fw-bold">
                                @Math.Round(item.TotalBudget, 2)
                            </td>
                            <td class="text-end text-info">
                                @Math.Round(item.AverageSalary, 2)
                            </td>
                        </tr>
                        counter++;
                    }
                </tbody>
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td colspan="2" class="text-end">Разом по університету:</td>
                        <td class="text-end text-danger fs-5">@Math.Round(totalUniversityBudget, 2) грн</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>