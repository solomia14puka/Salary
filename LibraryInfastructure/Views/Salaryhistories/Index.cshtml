@model IEnumerable<LibraryInfrastructure.Models.Salaryhistory>

@{
    ViewData["Title"] = "Зарплата";
}

<h1>Історія виплат для: @ViewBag.ScientistName</h1>

<p>
    @if (ViewBag.ScientistId != null)
    {
        <a asp-action="Create" asp-route-id="@ViewBag.ScientistId" class="btn btn-primary">Додати запис</a>
    }
</p>
<p>
    <a asp-controller="Scientists" asp-action="Index">До списку науковців</a>
    <a asp-action="Create" asp-route-id="@ViewBag.ScientistId" class="btn btn-primary"></a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Oldsalary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Newsalary)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Changedate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Reason)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Scientist)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Oldsalary)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Newsalary)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Changedate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Reason)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
